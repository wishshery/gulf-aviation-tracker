# Copy this file to .env and fill in your values
# ⚠  Never commit .env to git — it is in .gitignore

# Required: Anthropic API key for LLM extraction
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Serper.dev API key for Google search results (free tier available)
# Get one at https://serper.dev — much better results than DuckDuckGo fallback
SERPER_API_KEY=your_serper_key_here

# Optional: Override data/repo location
# GIT_REPO_PATH=/path/to/your/repo

# Optional: Days of history to keep in data files (default: 45)
# MAX_AGE_DAYS=45
